# ============================================================
# SPARKY Backend - Environment Variables
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=sparky-dev-secret-key-2026

DATABASE_URL=postgresql+asyncpg://sparky:sparky_pass@localhost:5432/sparky_db

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=sparky-documents

MISTRAL_API_KEY=VOTRE_CLE_MISTRAL_ICI
MISTRAL_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-12b-2409

N8N_WEBHOOK_URL=http://localhost:5678/webhook/sparky/notify
N8N_WEBHOOK_SECRET=sparky-secret

ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:3000"]
